---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import GoogleReviews from '../components/GoogleReviews.astro';
import ServicesCarousel from '../components/ServicesCarousel.astro';
import Doctors from '../components/Doctors.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import Insurance from '../components/Insurance.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Cross Creeks Dental | Gentle Dentist in Pickerington, OH"
  description="Dentist in Pickerington, OH accepting new patients. We accept Delta Dental PPO/Premier, MetLife, Guardian, Anthem, United Healthcare, Aetna, Cigna, Principal, Superior, Humana, Careington, Connection, and most insurance plans. Invisalign, implants, and emergency care available."
>
  <Navigation />
  <main class="flex-grow">
    <Hero />
    <GoogleReviews />
    <ServicesCarousel />
    <Doctors />
    <WhyChooseUs />
    <Insurance />
  </main>
  <Footer />
</Layout>

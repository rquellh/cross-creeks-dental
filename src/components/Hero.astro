---
import { Image } from 'astro:assets';
import womanSmiling from '../assets/images/woman-smiling.png';
import Button from './Button.astro';
import businessInfo from '../data/businessInfo.json';

const telHref = `tel:+1${businessInfo.phone.replace(/\D/g, '')}`;
---

<section class="relative bg-bg-main-darker text-white overflow-hidden py-40">
  <!-- Floating dental icons canvas -->
  <canvas id="dental-icons-canvas" class="sm:hidden absolute inset-0 w-full h-full pointer-events-none"></canvas>

  <div class="hidden sm:block absolute left-[50%] md:left-[48%] top-0 bottom-0 w-[50%] md:w-[52%] max-w-4xl">
    <Image
      src={womanSmiling}
      alt="Happy patient with a beautiful smile"
      class="w-full h-full object-cover object-left"
    />
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight text-brand-deep font-heading">
          Love your smile
        </h1>
        <p class="text-xl md:text-2xl mb-8 text-brand-deep">
          Whether it's been 6 months or 6 years since your last visit, we're here to help you—no judgment, just great care.
        </p>
        <div class="flex flex-col sm:flex-row gap-6 sm:gap-4">
          <Button
            variant="secondary"
            href="https://booking.adit.com/fdb30dd3-549e-48dd-89aa-f3fa2b9a5f2d"
            target="_blank"
            rel="noopener noreferrer"
          >
            Schedule Online
          </Button>
          <Button
            variant="secondary"
            href="https://crosscreeksdenta.securepayments.cardpointe.com/pay?"
            target="_blank"
            rel="noopener noreferrer"
          >
            Pay Bill Online
          </Button>
          <a
            href={telHref}
            class="sm:hidden inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md font-semibold transition-all duration-200 text-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-medium focus-visible:ring-offset-2 bg-white text-brand-deep hover:bg-bg-off-white active:scale-95"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Call {businessInfo.phone}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { initFloatingIcons } from '../utils/floatingTeeth';

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFloatingIcons);
  } else {
    initFloatingIcons();
  }
</script>
